rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidTask(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.userId == request.auth.uid &&
             data.completed is bool &&
             (data.priority in ['low', 'medium', 'high']) &&
             (data.estimated_pomodoros is int);
    }

    function isValidSession(data) {
      return data.userId == request.auth.uid &&
             data.durationMinutes is int &&
             data.type in ['focus', 'short_break', 'long_break'];
    }

    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidTask(request.resource.data);
      allow update: if isDocOwner() && isValidTask(request.resource.data) && 
                    request.resource.data.userId == resource.data.userId &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    match /focus_sessions/{sessionId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidSession(request.resource.data);
      allow update: if isDocOwner() && isValidSession(request.resource.data) &&
                    request.resource.data.userId == resource.data.userId &&
                    request.resource.data.startTime == resource.data.startTime;
      allow delete: if isDocOwner();
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
